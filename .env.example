# ═══════════════════════════════════════════════════════════════
#  19-Step Reservation Bot — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Telegram Bot ────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# Webhook (leave empty for polling mode in development)
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_random_secret_32_chars

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reservations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Application ─────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Timezone ────────────────────────────────────────────────────
TIMEZONE=Asia/Baghdad

# ── Reservation Rules ───────────────────────────────────────────
MAX_ACTIVE_RESERVATIONS=10
MAX_RESERVATION_DAYS_AHEAD=14
CHANNEL_CAPACITY_THRESHOLD=0.70

# ── Slot Schedule ───────────────────────────────────────────────
SLOT_START_HOUR=16
SLOT_END_HOUR=24
SLOT_DURATION_MINUTES=30

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
ANTI_FLOOD_SECONDS=0.5

# ── Admin ───────────────────────────────────────────────────────
# Comma-separated Telegram user IDs
ADMIN_IDS=
