# ═══════════════════════════════════════════════════════════════════════════
#  19-Step Reservation Bot — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values for your environment.
#  All scheduler jobs (reminders, broadcast) are timezone-aware and driven
#  by APScheduler — no external worker process required.
# ═══════════════════════════════════════════════════════════════════════════


# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# Webhook (leave empty to use polling mode — useful in development)
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_random_secret_32_chars_here


# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reservations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here


# ── Redis ────────────────────────────────────────────────────────────────────
# Used for: rate limiting, anti-flood, distributed scheduler locks, FSM storage
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000


# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json


# ── Timezone ─────────────────────────────────────────────────────────────────
# All scheduler jobs (reminders, broadcast) run in this timezone.
# Must be a valid pytz timezone string.
TIMEZONE=Asia/Baghdad


# ── Reservation Rules ────────────────────────────────────────────────────────
MAX_ACTIVE_RESERVATIONS=10
MAX_RESERVATION_DAYS_AHEAD=14
# Fraction of channel capacity at which secondary channels become visible (0–1)
CHANNEL_CAPACITY_THRESHOLD=0.70
# Hour (0-23, TIMEZONE) after which same-day reservations are blocked
SAME_DAY_CUTOFF_HOUR=12
# Hour (0-23, TIMEZONE) after which same-day cancellations are blocked
SAME_DAY_CANCEL_CUTOFF_HOUR=12


# ── Slot Schedule ────────────────────────────────────────────────────────────
# Sessions are generated in SLOT_DURATION_MINUTES intervals between these hours.
SLOT_START_HOUR=16
SLOT_END_HOUR=24
SLOT_DURATION_MINUTES=30

# Special terminal slot appended after the interval range.
# Stays on the same calendar day — avoids midnight rollover.
# Set ENABLE_FINAL_MIDNIGHT_SLOT=false to disable entirely.
ENABLE_FINAL_MIDNIGHT_SLOT=true
FINAL_SLOT_TIME=23:59


# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
ANTI_FLOOD_SECONDS=0.5


# ── Notifications & Reminders ────────────────────────────────────────────────
# Reminders are sent automatically by the APScheduler background worker.
# No external Celery or task-queue process is required.

# Hour (0-23, TIMEZONE) at which same-day session reminders are dispatched.
# Sent once per day to users who have a reservation on that day.
SAME_DAY_REMINDER_HOUR=12

# Minutes before session start to send the pre-session reminder.
# The scheduler polls every 5 minutes with a ±5-minute window around this value.
PRE_SESSION_REMINDER_MINUTES=30


# ── Daily Schedule Broadcast ─────────────────────────────────────────────────
# At DAILY_BROADCAST_HOUR each day, the bot publishes today's session schedule
# to every active Telegram channel. Each channel receives only its own reservations.
# Special event blocks (e.g. Dhikr gatherings) can be injected via the
# schedule_events table without any code changes.

# Hour (0-23, TIMEZONE) to broadcast the daily session schedule.
DAILY_BROADCAST_HOUR=12

# Pin the broadcast message in the channel after sending.
# Requires the bot to have 'Pin messages' admin permission in the channel.
ENABLE_BROADCAST_AUTO_PIN=true

# Delete the previous day's broadcast message when publishing today's.
# Keeps the channel feed clean. Set to false to retain message history.
DELETE_PREVIOUS_BROADCAST=false


# ── Channels ─────────────────────────────────────────────────────────────────
# Each channel entry defines one Telegram live-session group or channel.
# Channels are loaded dynamically — add CHANNEL_2_*, CHANNEL_3_* etc. as needed.
#
# CHANNEL_N_ID      Telegram channel/group ID (negative integer, e.g. -1001234567890)
#                   The bot must be an admin with 'Post messages' and 'Pin messages'
#                   permissions for broadcast and pinning to work.
# CHANNEL_N_NAME    Display name shown in reservation confirmations and reminders.
# CHANNEL_N_INVITE  Public invite link (https://t.me/+xxxx) included in reminders
#                   and the daily broadcast message.
#
# Channel priority follows the numeric suffix (1 = primary / recommended).
# Secondary channels (2+) become visible when channel 1 reaches CHANNEL_CAPACITY_THRESHOLD.
#
# Each channel:
#   • receives its own daily schedule broadcast
#   • displays only its own reservations
#   • sends reminders with its own name and invite link

CHANNEL_1_ID=-1001000000001
CHANNEL_1_NAME=Echoes
CHANNEL_1_INVITE=https://t.me/+your_invite_link_here

# CHANNEL_2_ID=-1001000000002
# CHANNEL_2_NAME=Overflow
# CHANNEL_2_INVITE=https://t.me/+your_second_invite_link

# CHANNEL_3_ID=
# CHANNEL_3_NAME=
# CHANNEL_3_INVITE=


# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs granted admin privileges.
ADMIN_IDS=
